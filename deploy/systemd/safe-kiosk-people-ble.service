[Unit]
Description=Safe Kiosk Bluetooth collector
After=systemd-tmpfiles-setup.service
OnFailure=safe-kiosk-people-recover@ble.service
[Service]
Type=notify
NotifyAccess=main
ExecStart=/opt/safe-kiosk-people-agent/venv/bin/safe-kiosk-people-ble --config /etc/safe-kiosk-people-agent/config.toml
WatchdogSec=60s
Restart=on-failure
RestartSec=10s
KillMode=control-group
TimeoutStopSec=20s
SendSIGKILL=yes
MemoryHigh=192M
MemoryMax=256M
Slice=safe-kiosk-people-agent.slice
User=safe-kiosk-people-agent
